{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "./",
    "paths": {
      "@config/*": ["./config/*.js"],
      "@infra/*": ["./infra/*.js"],
      "@workspaces/*": ["./modules/workspaces/*.js"],
      "@project/*":["./modules/projects/*.js"],
      "@user/*": ["./modules/user/*.js"],
      "@auth/*": ["./modules/auth/*.js"],
      "@error/*": ["./error/*.js"],
      "@type/*": ["./types/*.js"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
